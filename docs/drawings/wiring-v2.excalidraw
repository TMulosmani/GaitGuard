    {"type":"text","id":"pid","x":55,"y":695,"width":490,"height":60,"text":"Ethernet to router  |  No physical sensor connections\nRuns: gaitguard (C) — complementary filter + LSTM digital twin + scoring\nRuns: web dashboard (Python HTTP, port 8080)\nReceives UDP from ESPs → processes → sends haptic + display cmds back","originalText":"Ethernet to router  |  No physical sensor connections\nRuns: gaitguard (C) — complementary filter + LSTM digital twin + scoring\nRuns: web dashboard (Python HTTP, port 8080)\nReceives UDP from ESPs → processes → sends haptic + display cmds back","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":4005,"version":1,"versionNonce":4006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

