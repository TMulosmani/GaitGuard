    {"type":"text","id":"lct","x":890,"y":152,"width":200,"height":86,"text":"ST7789V2 LCD 240×280\nMOSI=7  SCLK=6  CS=5\nDC=4  RST=8  BL=15\nSPI Interface\nTouch: CST816T (0x15)\nRTC: PCF85063 (0x51)","originalText":"ST7789V2 LCD 240×280\nMOSI=7  SCLK=6  CS=5\nDC=4  RST=8  BL=15\nSPI Interface\nTouch: CST816T (0x15)\nRTC: PCF85063 (0x51)","fontSize":11,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#6d28d9","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3032,"version":1,"versionNonce":3033,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"lc","lineHeight":1.25},
    {"type":"text","id":"e2n","x":620,"y":270,"width":490,"height":55,"text":"All components onboard — no external wiring needed\nDisplays: Live GHS score, color bar (green/yellow/red), state text\nPowered via USB-C  |  Battery ADC on GPIO 1","originalText":"All components onboard — no external wiring needed\nDisplays: Live GHS score, color bar (green/yellow/red), state text\nPowered via USB-C  |  Battery ADC on GPIO 1","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3040,"version":1,"versionNonce":3041,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

