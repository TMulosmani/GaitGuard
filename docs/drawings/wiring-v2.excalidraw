    {"type":"text","id":"wft","x":615,"y":478,"width":230,"height":20,"text":"WiFi UDP Communication","originalText":"WiFi UDP Communication","fontSize":16,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":5003,"version":1,"versionNonce":5004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"wfn","x":880,"y":480,"width":230,"height":14,"text":"Network: UNH_ROBOT_24","originalText":"Network: UNH_ROBOT_24","fontSize":12,"fontFamily":3,"textAlign":"right","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":5007,"version":1,"versionNonce":5008,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"wff","x":615,"y":510,"width":490,"height":245,"text":"ESP#1 (Thigh/Shin) ────UDP :5001────→ Raspberry Pi\n  Packet: [0x01 | seq:2B | thigh(ax,ay,az,gx,gy,gz):12B | shin:12B] = 27B\n  Rate: 50 Hz  |  MPU-6050 ±4g / ±500°/s\n\nRaspberry Pi ────UDP :5003────→ ESP#1\n  Packet: [pattern:1B | intensity:1B] = 2B\n  Patterns: 1=TWO_SHORT  2=ONE_LONG  3=THREE_SHORT\n\nESP#2 (Foot) ────UDP :5002────→ Raspberry Pi\n  Packet: [0x02 | seq:2B | foot(ax,ay,az,gx,gy,gz):12B] = 15B\n  Rate: 50 Hz  |  QMI8658C ±4g / ±512°/s\n\nRaspberry Pi ────UDP :5004────→ ESP#2\n  Packet: [cmd:1B | ghs_hi:1B | ghs_lo:1B | color:1B | state:1B | 0] = 6B\n  Updates LCD with GHS score and color indicator\n\nWeb dashboard: http://192.168.1.249:8080","originalText":"ESP#1 (Thigh/Shin) ────UDP :5001────→ Raspberry Pi\n  Packet: [0x01 | seq:2B | thigh(ax,ay,az,gx,gy,gz):12B | shin:12B] = 27B\n  Rate: 50 Hz  |  MPU-6050 ±4g / ±500°/s\n\nRaspberry Pi ────UDP :5003────→ ESP#1\n  Packet: [pattern:1B | intensity:1B] = 2B\n  Patterns: 1=TWO_SHORT  2=ONE_LONG  3=THREE_SHORT\n\nESP#2 (Foot) ────UDP :5002────→ Raspberry Pi\n  Packet: [0x02 | seq:2B | foot(ax,ay,az,gx,gy,gz):12B] = 15B\n  Rate: 50 Hz  |  QMI8658C ±4g / ±512°/s\n\nRaspberry Pi ────UDP :5004────→ ESP#2\n  Packet: [cmd:1B | ghs_hi:1B | ghs_lo:1B | color:1B | state:1B | 0] = 6B\n  Updates LCD with GHS score and color indicator\n\nWeb dashboard: http://192.168.1.249:8080","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":5005,"version":1,"versionNonce":5006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25}
